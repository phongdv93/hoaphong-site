# PostgreSQL — Platform DB (users, companies, company_members, modules, CMS)
# Tạo DB: npm run db:create-erp
DATABASE_URL=postgresql://postgres:MAT_KHAU@localhost:5432/erp

# Tiền tố tên DB tenant mỗi công ty (mặc định erp_t_1_<code>)
# TENANT_DB_PREFIX=erp_t_

# URL admin để CREATE DATABASE tenant (mặc định = DATABASE_URL với database postgres)
# POSTGRES_ADMIN_URL=postgresql://postgres:MAT_KHAU@localhost:5432/postgres

# JWT secret for ERP sessions (change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-me

# Subdomain ERP theo công ty: {subdomain}.hoaphong.com.vn (dev: http://{subdomain}.localhost:3000)
# ERP_HOST_SUFFIX=hoaphong.com.vn
# URL gốc site (dev: link ERP/mail dùng http + *.localhost; VPS IP: http://123.45.67.89)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# Deploy VPS chưa có domain — bắt buộc set IP + HTTP:
# NEXT_PUBLIC_APP_URL=http://123.45.67.89
# ERP_HTTP=1

# Gửi email mật khẩu / thông báo duyệt (bỏ trống = in ra console khi dev)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=your@gmail.com
# SMTP_PASS=app-password
# MAIL_FROM="Hoa Phong ERP <noreply@hoaphong.com.vn>"

# Tự duyệt đăng ký doanh nghiệp (/erp/register)
# COMPANY_VERIFY_RULES_ONLY=1 — chỉ kiểm tra MST + trùng DB (mặc định bật khi không có API tra cứu)
# COMPANY_MST_VERIFY_URL=https://your-api.example/company?taxCode={taxCode}
#   JSON trả về: { "officialName", "name", "status": "active"|"inactive", "address" }
# OPENAI_API_KEY= — so khớp tên công ty với tên tra cứu MST (tùy chọn)
# OPENAI_MODEL=gpt-4o-mini

ADMIN_EMAIL=phongdv93@gmail.com
ADMIN_PASSWORD=admin123

# --- Xuất nhập khẩu / VNACCS ---
# URL gateway do đối tác chứng thực HQ cung cấp (ECUS gateway, EDI, v.v.)
# CUSTOMS_VNACCS_GATEWAY_URL=https://your-vnaccs-gateway.example/v1
# CUSTOMS_VNACCS_FORCE_SIMULATE=1
# Mã hóa mật khẩu VNACCS lưu DB (mặc định dùng JWT_SECRET)
# CUSTOMS_CREDENTIALS_SECRET=

# Đối soát "thông tin thật" trước khi gửi:
# API hóa đơn/vận đơn phải trả JSON có matched:boolean hoặc exists:boolean
# Ví dụ: GET /verify/invoice?invoiceNo=...&importerTaxCode=...&invoiceDate=...
# CUSTOMS_INVOICE_VERIFY_URL=https://your-provider.example/verify/invoice
# Ví dụ: GET /verify/bol?billOfLadingNo=...&importerTaxCode=...
# CUSTOMS_BOL_VERIFY_URL=https://your-provider.example/verify/bol
# CUSTOMS_EXTERNAL_VERIFY_TOKEN=your-api-token
# CUSTOMS_EXTERNAL_VERIFY_TIMEOUT_MS=12000

# Local signing agent (Windows machine cắm USB token)
# CUSTOMS_SIGNING_AGENT_URL=http://127.0.0.1:8777
# CUSTOMS_SIGNING_AGENT_TOKEN=change-me

# --- Lưu trữ S3 (tài liệu dự án, file đính kèm) ---
# S3_ENDPOINT=https://s3.onie.net
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=hoaphong
# URL public (tuỳ chọn — mặc định: {S3_ENDPOINT}/{S3_BUCKET}/)
# S3_PUBLIC_URL=

# --- Xuất XML / Bot RPA cổng e-declaration (không cần API VNACCS) ---
# Mẫu vàng: data/customs/golden-ida-sample.xml (export từ ECUS/cổng HQ để so khớp 100%)
# Bot: scripts/customs-portal-rpa — CUSTOMS_PORTAL_USER, CUSTOMS_PORTAL_PASSWORD, CUSTOMS_IDA_XML_PATH
